{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "rusbview",
  "version": "0.1.0",
  "identifier": "io.github.halfsweet.rusbview",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "rusbview",
        "width": 1180,
        "height": 760,
        "minWidth": 920,
        "minHeight": 620,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDI1OEYzQTBBRkVEQ0E5REQKUldUZHFkeitDanFQSlZRVDVucWp6ZDNHTWxDS0w2WVZUVFYzRGRjUTlKTjExUGx5YlVMZktEVWkK",
      "endpoints": [
        "https://github.com/HalfSweet/rusbview/releases/latest/download/latest.json"
      ]
    }
  }
}
